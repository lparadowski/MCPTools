# Trello — https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_TOKEN=

# Jira — https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# Confluence — same Atlassian credentials as Jira
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# Miro — https://miro.com/app/settings/user-profile/apps
MIRO_ACCESS_TOKEN=

# SSL validation — set to true if behind a corporate proxy that intercepts HTTPS
# with a custom root CA. Only use in development environments.
DISABLE_SSL_VALIDATION=false
